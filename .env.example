# PostgreSQL Configuration
POSTGRES_USER=digitax
POSTGRES_PASSWORD=digitax
POSTGRES_DB=digitax
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Backend Application
DATABASE_URL=postgresql+asyncpg://digitax:digitax@postgres:5432/digitax
APP_NAME=DigiTax Backend
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# Frontend Build Proxy (optional, for restricted networks)
FRONTEND_BUILD_HTTP_PROXY=
FRONTEND_BUILD_HTTPS_PROXY=
FRONTEND_BUILD_ALL_PROXY=

# Frontend SSR Application
# VITE_API_BASE_URL is a build-time public API base URL baked into frontend bundles.
# Use /api/v1 for reverse-proxy same-origin deployments.
# For direct port testing, an operator may set a full API URL externally in .env.
# Rebuild the frontend image after changing this value; do not commit .env.
VITE_API_BASE_URL=/api/v1
VITE_API_TIMEOUT_MS=30000
FRONTEND_PORT=3000

# Runtime-only frontend secrets. Leave empty in examples and never pass as build args.
LOVABLE_API_KEY=
