digi-tax-ops/.env.example#L1-30
# PostgreSQL Configuration
POSTGRES_USER=digitax
POSTGRES_PASSWORD=digitax
POSTGRES_DB=digi_tax
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Backend Application
DATABASE_URL=postgresql+asyncpg://digitax:digitax@postgres:5432/digitax
APP_NAME=DigiTax Backend
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# Frontend Build Proxy (optional, for restricted networks)
FRONTEND_BUILD_HTTP_PROXY=
FRONTEND_BUILD_HTTPS_PROXY=
FRONTEND_BUILD_ALL_PROXY=

# Frontend Application
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_TIMEOUT_MS=30000
