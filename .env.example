# PostgreSQL Configuration
POSTGRES_USER=digitax
POSTGRES_PASSWORD=digitax
POSTGRES_DB=digi_tax
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

