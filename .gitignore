.env
.env.*
!.env.example

# Dev/test-server connection vars ($DIGI_TEST_SSH / $DIGI_TEST_PATH) — never commit the IP/SSH
.deploy.env

# Design reference — local only, never commit
_design_reference/

.DS_Store
.idea/
.vscode/
.zed/

*.log

# Claude Code QA artifacts
*.png
claude_partial_*.txt
claude_partial_*.diff
.claude/settings.local.json
.serena/

# Local screenshot-sweep QA output (workspace-root level, not repo content)
qa-screens/

# Pre-reseed DB snapshots taken automatically by scripts/reset_world.sh
.reseed-snapshots/
*.sql.gz

# STUFFID catalog archives (~150MB compressed / ~2GB raw) — NEVER in git.
# The convention (naming, download, packing) is documented in data/stuffid/README.md,
# which IS committed. Operators drop the archive; the api imports it at boot.
data/stuffid/*
!data/stuffid/README.md
